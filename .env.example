# Copy to .env and fill in. Only the auth + AI keys are required for a real deploy.

# --- core ---
WORLDS_BASE_DOMAIN=worlds.localhost      # base host; sites at <site>.<base> (subdomain) or <base>/app/<site> (path)
# "subdomain" (default): each site gets its own subdomain — needs wildcard DNS + a
# wildcard TLS cert. "path": sites at <base>/app/<site> off ONE host — no wildcard
# needed (works on free Cloudflare), at the cost of per-site origin isolation.
WORLDS_ROUTING=subdomain
WORLDS_PORT=8420
WORLDS_DATA_DIR=./data                  # site + upload storage (mount a volume in prod)
DATABASE_URL=postgres://world:world@localhost:5499/world

# --- auth ---
# "google" = built-in Google sign-in (default). "gateway" = trust a verified-email
# header from an upstream proxy (oauth2-proxy / IAP / Cloudflare Access).
WORLDS_AUTH=google
# Two google flows, picked automatically by what you set:
#  • ID + SECRET → server-side code flow (redirect URI  https://<your-domain>/auth/callback)
#  • ID only (no secret) → Google Identity Services button (verifies the ID token
#    against Google's JWKS). Needs no secret, so you can reuse an existing PUBLIC web
#    client — just add  https://<your-domain>  to its "Authorized JavaScript origins".
# Create/manage clients at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Restrict sign-in (comma-separated). Empty = any Google account.
WORLDS_ALLOWED_DOMAINS=
WORLDS_ALLOWED_EMAILS=
# REQUIRED in prod: a long random string (e.g. `openssl rand -hex 32`).
WORLDS_SESSION_SECRET=
# External origin for the OAuth redirect, e.g. https://world.example.com. Needed
# behind a wildcard so sign-in always happens on the base domain.
WORLDS_PUBLIC_ORIGIN=

# --- remote storage (optional) ---
# Set a bucket to store deploys + uploads in S3 (or any S3-compatible store) instead
# of local disk; bundled apps still ship locally and reads fall through to them.
# Credentials come from the standard AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY env.
WORLDS_S3_BUCKET=
WORLDS_S3_REGION=
WORLDS_S3_ENDPOINT=                    # for R2/MinIO/etc.; omit for AWS S3

# --- AI (optional but recommended) ---
GEMINI_API_KEY=                        # enables worlds.ai; get one at https://aistudio.google.com/apikey

# --- integrations (optional) ---
SLACK_BOT_TOKEN=                       # enables worlds.notify.slack

# --- misc (optional) ---
WORLDS_SEED=1                           # seed the universe as the first world on boot (0 to skip)
WORLDS_CHROME=                          # path to a Chrome/Chromium binary for screenshot thumbnails
WORLDS_DEV=                             # set to 1 only for local dev (stubs identity, no real auth)
