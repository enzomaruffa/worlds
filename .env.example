# Copy to .env and fill in. Only the auth + AI keys are required for a real deploy.

# --- core ---
WORLD_BASE_DOMAIN=world.localhost      # wildcard base; <site>.<base> → that site, bare base → homepage
WORLD_PORT=8420
WORLD_DATA_DIR=./data                  # site + upload storage (mount a volume in prod)
DATABASE_URL=postgres://world:world@localhost:5499/world

# --- auth ---
# "google" = built-in Google sign-in (default). "gateway" = trust a verified-email
# header from an upstream proxy (oauth2-proxy / IAP / Cloudflare Access).
WORLD_AUTH=google
# Create an OAuth client at https://console.cloud.google.com/apis/credentials
# with redirect URI  https://<your-domain>/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Restrict sign-in (comma-separated). Empty = any Google account.
WORLD_ALLOWED_DOMAINS=
WORLD_ALLOWED_EMAILS=
# REQUIRED in prod: a long random string (e.g. `openssl rand -hex 32`).
WORLD_SESSION_SECRET=
# External origin for the OAuth redirect, e.g. https://world.example.com. Needed
# behind a wildcard so sign-in always happens on the base domain.
WORLD_PUBLIC_ORIGIN=

# --- AI (optional but recommended) ---
GEMINI_API_KEY=                        # enables world.ai; get one at https://aistudio.google.com/apikey

# --- integrations (optional) ---
SLACK_BOT_TOKEN=                       # enables world.notify.slack

# --- misc (optional) ---
WORLD_SEED=1                           # seed the universe as the first world on boot (0 to skip)
WORLD_CHROME=                          # path to a Chrome/Chromium binary for screenshot thumbnails
WORLD_DEV=                             # set to 1 only for local dev (stubs identity, no real auth)
